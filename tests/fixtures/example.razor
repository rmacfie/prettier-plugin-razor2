@page "/inventory/{WarehouseId:int}"
@layout AdminLayout
@namespace MyApp.Components.Inventory
@using System.Linq
@using MyApp.Models
@inject ILogger<InventoryPage> Logger
@inject IInventoryService Inventory
@implements IAsyncDisposable
@attribute [Authorize(Roles = "Warehouse")]
@rendermode InteractiveServer

<PageTitle>Inventory — warehouse @WarehouseId</PageTitle>

@* Toolbar: search box (immediate binding) and a guarded delete-all button. *@
<header class="toolbar">
  <input
    @bind:get="query"
    @bind:set="OnQueryChanged"
    placeholder="Search stock..."
  />
  <button
    class="danger"
    @onclick="DeleteAll"
    @onclick:preventDefault
    @onclick:stopPropagation
    disabled="@(!items.Any())"
  >
    Delete all
  </button>
</header>

@if (loadError is not null)
{
  <Alert Severity="AlertSeverity.Error">@loadError</Alert>
}
else if (items.Count == 0)
{
  <p>
    No stock in warehouse @WarehouseId. <a href="/inventory">Pick another</a>.
  </p>
}
else
{
  <Grid TItem="StockItem" Items="items">
    <Header>
      <h2>@items.Count item(s), worth @(items.Sum(i => i.Value).ToString("C"))</h2>
    </Header>
    <Body>
      @foreach (var item in items.Where(i => i.Matches(query)))
      {
        <GridRow @key="item.Sku">
          <td>@item.Sku</td>
          <td>@item.Name</td>
          <td><InputNumber @bind-Value="item.Quantity" /></td>
          <td><button @onclick="() => Remove(item.Sku)">Remove</button></td>
        </GridRow>
      }
    </Body>
  </Grid>

  @for (var page = 1; page <= pageCount; page++)
  {
    <PageLink Page="page" Current="page == currentPage" />
  }
}

@try
{
  <StockTicker
    Feed="feed"
    @rendermode="InteractiveServer"
    @attributes="TickerAttrs"
  />
}
catch (FeedUnavailableException ex)
{
  <p class="muted">Ticker offline: @ex.Reason</p>
}
finally
{
  <span data-probe="ticker-rendered"></span>
}

@code {
  [Parameter]
  public int WarehouseId { get; set; }

  private List<StockItem> items = [];
  private string query = "";
  private string? loadError;
  private int currentPage = 1;
  private int pageCount;
  private FeedHandle? feed;

  private Dictionary<string, object> TickerAttrs =>
    new() { ["role"] = "status" };

  protected override async Task OnParametersSetAsync()
  {
    try
    {
      items = await Inventory.GetStockAsync(WarehouseId);
      pageCount = (items.Count + 49) / 50;
    }
    catch (Exception ex)
    {
      Logger.LogError(
        ex,
        "Failed to load warehouse {WarehouseId}",
        WarehouseId
      );
      loadError = "Could not load stock.";
    }
  }

  private void OnQueryChanged(string value)
  {
    query = value.Trim();
    currentPage = 1;
  }

  private async Task Remove(string sku)
  {
    await Inventory.RemoveAsync(WarehouseId, sku);
    items.RemoveAll(i => i.Sku == sku);
  }

  private Task DeleteAll() => Inventory.ClearAsync(WarehouseId);

  public async ValueTask DisposeAsync()
  {
    if (feed is not null)
      await feed.DisposeAsync();
  }
}

@code {
  // A second @code block is legal and kept separate.
  private const string ProbeTemplate = """
{ "probe": "inventory", "v": 2 }
""";
}
