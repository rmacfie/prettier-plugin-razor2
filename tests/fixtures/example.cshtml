@page
@model ProductCatalogModel
@using MyApp.Catalog
@inject IPricingService Pricing
@{
  ViewData["Title"] = "Catalog";
  Layout = "_Layout";
  var featured = Model.Products.FirstOrDefault(p => p.IsFeatured);
}

@section Head
{
  <meta name="description" content="Our product catalog" />
}

<h1>@ViewData["Title"]</h1>

@* Show a banner for the featured product, when there is one. *@
@if (featured is not null)
{
  <div class="banner">
    <h2>Featured: @featured.Name</h2>
    <p>@Html.Raw(featured.DescriptionHtml)</p>
  </div>
}

<form asp-controller="Catalog" asp-action="Search" method="get">
  <input asp-for="Query" class="form-control" />
  <button type="submit">Search</button>
</form>

<ul class="products">
  @foreach (var product in Model.Products)
  {
    <li>
      <a asp-controller="Catalog" asp-action="Details" asp-route-id="@product.Id"
        >@product.Name</a
      >
      <span>@(Pricing.Format(product.Price))</span>
    </li>
  }
</ul>

<partial name="_Pagination" model="Model.Pager" />

@section Scripts
{
  <script src="~/js/catalog.js" asp-append-version="true"></script>
}
