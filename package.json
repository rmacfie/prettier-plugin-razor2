{
  "name": "prettier-plugin-razor2",
  "version": "1.0.0",
  "description": "Prettier plugin for Razor (Blazor) files — a fork of prettier-plugin-razor",
  "keywords": [
    "prettier",
    "razor",
    "blazor",
    "plugin"
  ],
  "homepage": "https://github.com/rmacfie/prettier-plugin-razor2#readme",
  "bugs": {
    "url": "https://github.com/rmacfie/prettier-plugin-razor2/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rmacfie/prettier-plugin-razor2.git"
  },
  "license": "MIT",
  "author": {
    "name": "Robert Macfie",
    "email": "robert@macfie.se"
  },
  "contributors": [
    {
      "name": "Kristina Corrado",
      "url": "https://github.com/KristinaPlusPlus/prettier-plugin-razor"
    }
  ],
  "main": "src/index.js",
  "scripts": {
    "example": "prettier --plugin ./src/index.js example.razor",
    "format": "prettier --write .",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "void-elements": "^3.1.0"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "prettier-plugin-jsdoc": "1.8.1",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  }
}
