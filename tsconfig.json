{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",

    // Author with explicit `.ts` specifiers (needed for Node's native TS
    // execution) and let tsc rewrite them to `.js` in the emitted output.
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    // Keep the source to type-erasable syntax so Node can run it directly.
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
